# Configuration template for st-gsheets-connection
# Copy this file to .streamlit/secrets.toml and fill in your service account details.

[connections.gsheets]
spreadsheet = "https://docs.google.com/spreadsheets/d/1EaHaNMNmqz2Yy-3DpaNktbi4Ii0vRvaz4lwjpL71zYg/edit"

# Service Account credentials for secure access (from your Google Cloud IAM service account key JSON)
[connections.gsheets.configuration]
type = "service_account"
project_id = "thuc-hanh-bai-7"
private_key_id = "YOUR_PRIVATE_KEY_ID"
private_key = "-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
client_email = "thuc-hanh-bai-7@thuc-hanh-bai-7.iam.gserviceaccount.com"
client_id = "YOUR_CLIENT_ID"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs/thuc-hanh-bai-7%40thuc-hanh-bai-7.iam.gserviceaccount.com"
universe_domain = "googleapis.com"
